PORT=3000

DB_HOST=your-production-mysql-host
DB_PORT=3306
DB_USER=your-production-mysql-user
DB_PASSWORD=your-production-mysql-password
DB_NAME=teen_chat_town
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true
DB_CA_CERT=

JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars

SITE_ORIGIN=https://teenchattown.info
PUBLIC_URL=https://teenchattown.info

# Random Talk sessions, matching, safety, and low-data calls
GUEST_SESSION_MINUTES=180
GUEST_SESSIONS_PER_DAY=3
WELCOME_RETURN_THRESHOLD_MINUTES=120
RANDOM_MATCH_TIMEOUT_SECONDS=180
RANDOM_RECONNECT_GRACE_SECONDS=30
RANDOM_TALK_MESSAGE_MAX=500
RANDOM_TALK_INTEREST_WAIT_MS=7000
RANDOM_TALK_QUEUE_TTL_MS=180000
RANDOM_TALK_SKIP_COOLDOWN_MS=2500
QUIZ_ROOM_QUESTION_SECONDS=15
QUIZ_NEXT_QUESTION_DELAY_MS=2000
QUIZ_CONTEST_QUESTION_SECONDS=10
QUIZ_CONTEST_JOIN_GRACE_SECONDS=60
WEBRTC_STUN_URLS=stun:your-stun-host.example:3478
WEBRTC_TURN_URLS=turn:your-turn-host.example:3478?transport=udp,turn:your-turn-host.example:3478?transport=tcp,turns:your-turn-host.example:5349?transport=tcp
WEBRTC_TURN_USERNAME=
WEBRTC_TURN_CREDENTIAL=

# Hosted payment providers remain disabled until valid sandbox/production secrets are configured.
PAYMENT_PROVIDER=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_WEBHOOK_SECRET=
CASHFREE_ENVIRONMENT=sandbox
